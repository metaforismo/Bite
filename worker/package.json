{
  "name": "bite-worker",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:generate": "drizzle-kit generate",
    "db:migrate:local": "wrangler d1 migrations apply bite_db --local",
    "db:migrate:remote": "wrangler d1 migrations apply bite_db --remote"
  },
  "dependencies": {
    "hono": "^4.6.14",
    "drizzle-orm": "^0.36.4",
    "firebase-admin": "^13.0.1",
    "jose": "^5.9.6",
    "zod": "^3.24.1",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "typescript": "^5.7.2",
    "wrangler": "^3.99.0",
    "drizzle-kit": "^0.30.0",
    "vitest": "^2.1.8",
    "@cloudflare/vitest-pool-workers": "^0.5.40",
    "@cloudflare/workers-types": "^4.20241218.0",
    "@types/node": "^22.10.2"
  }
}
