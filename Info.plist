<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!--
		BITE_API_BASE_URL — overrideable via xcconfig per scheme. Leaving the
		empty string here makes BiteAPIConfig fall back to http://localhost:8787
		(local Wrangler dev). For TestFlight/Release set this to your deployed
		Worker URL e.g. https://bite-worker.<account>.workers.dev
	-->
	<key>BITE_API_BASE_URL</key>
	<string>http://localhost:8787</string>
	<key>CFBundleIcons</key>
	<dict>
		<key>CFBundleAlternateIcons</key>
		<dict>
			<key>AppIcon-ClearDark</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-ClearDark</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>AppIcon-ClearLight</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-ClearLight</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>AppIcon-Dark</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-Dark</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>AppIcon-TintedDark</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-TintedDark</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
			<key>AppIcon-TintedLight</key>
			<dict>
				<key>CFBundleIconFiles</key>
				<array>
					<string>AppIcon-TintedLight</string>
				</array>
				<key>UIPrerenderedIcon</key>
				<false/>
			</dict>
		</dict>
	</dict>
</dict>
</plist>
